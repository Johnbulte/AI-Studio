{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Studio OS",
  "version": "0.1.0",
  "identifier": "com.aistudio.os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Studio OS",
        "width": 1440,
        "height": 1024,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#0a0a0b00",
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
